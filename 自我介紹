<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>郭展華 | AI & AIOT 冒險者履歷</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;900&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #f0f0f0;
            font-family: 'Noto Sans TC', sans-serif;
            color: #000;
        }

        .manga-page {
            background-color: #fff;
            border: 5px solid #000;
            padding: 20px;
            box-shadow: 15px 15px 0px #000;
            position: relative;
            overflow: hidden;
        }

        .manga-panel {
            border: 4px solid #000;
            position: relative;
            background: #fff;
            transition: transform 0.2s;
            overflow: hidden;
        }

        .speed-lines {
            background: repeating-linear-gradient(
                45deg,
                rgba(0,0,0,0.05),
                rgba(0,0,0,0.05) 1px,
                transparent 1px,
                transparent 10px
            );
        }

        .speech-bubble {
            position: relative;
            background: #fff;
            border: 3px solid #000;
            border-radius: 20px;
            padding: 12px;
            display: inline-block;
            font-weight: 900;
            font-size: 0.75rem;
        }

        .impact-text {
            font-weight: 900;
            color: #ff0000;
            text-shadow: 2px 2px 0px #000;
            transform: rotate(-3deg);
        }

        .manga-title {
            font-weight: 900;
            font-size: 2.2rem;
            border-bottom: 8px solid #000;
            display: inline-block;
            margin-bottom: 15px;
        }

        .manga-nav-btn {
            border: 3px solid #000;
            padding: 10px;
            font-weight: 900;
            background: #fff;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.9rem;
        }

        .manga-nav-btn:hover {
            background: #ffff00;
            transform: translate(-2px, -2px);
            box-shadow: 4px 4px 0px #000;
        }

        .manga-nav-btn.active {
            background: #ff0000;
            color: #fff;
        }

        .content-section {
            display: none;
        }

        .content-section.active {
            display: block;
            animation: fadeIn 0.4s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .skill-bar-container {
            border: 3px solid #000;
            height: 24px;
            background: #fff;
            position: relative;
        }

        .skill-bar-fill {
            height: 100%;
            border-right: 3px solid #000;
        }

        .halftone {
            background-image: radial-gradient(#000 15%, transparent 16%);
            background-size: 8px 8px;
            opacity: 0.05;
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
        }

        .badge {
            background: #000;
            color: #fff;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: bold;
            margin-right: 5px;
        }
    </style>
</head>
<body class="p-4 md:p-8 flex justify-center">

    <div class="max-w-5xl w-full manga-page min-h-[90vh] flex flex-col">
        <div class="halftone"></div>

        <!-- 頁首：狀態欄 -->
        <div class="flex flex-col md:flex-row justify-between items-start mb-6 border-b-4 border-black pb-4 relative z-10">
            <div>
                <h1 class="manga-title">郭展華 <span class="text-sm font-normal ml-2">Guo Zhan-Hua</span></h1>
                <div class="flex flex-wrap gap-2 mt-1">
                    <span class="badge">年齡: 23</span>
                    <span class="badge bg-blue-600">興趣: 打排球 🏐 / 玩遊戲 🎮</span>
                </div>
            </div>
            <div class="mt-4 md:mt-0 text-right">
                <div class="speech-bubble mb-2">
                    「結合 AI 數據洞察與自動化技術，<br>創造超額行銷價值！」
                </div>
            </div>
        </div>

        <!-- 主要故事分格區域 -->
        <div id="manga-content" class="relative z-10 flex-grow">

            <!-- EPISODE 1: 序幕 / 核心願景 -->
            <div id="page-home" class="content-section active">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                    <div class="manga-panel md:col-span-8 p-6 speed-lines min-h-[250px] flex flex-col justify-center">
                        <h2 class="text-2xl font-black mb-4 bg-yellow-300 inline-block px-2">MISSION: AI 驅動進化</h2>
                        <p class="text-lg leading-relaxed font-bold">
                            從 <span class="text-blue-600">數位行銷</span> 跨足 <span class="text-red-600">AIOT 智慧聯網</span>，<br>
                            致力於將技術轉化為實際商業應用。
                        </p>
                        <div class="mt-6 flex flex-wrap gap-3">
                            <div class="border-2 border-black p-2 font-black text-sm rotate-1">#AIOT 應用開發</div>
                            <div class="border-2 border-black p-2 font-black text-sm -rotate-1">#AI 驅動行銷</div>
                        </div>
                    </div>
                    <div class="manga-panel md:col-span-4 p-4 bg-blue-50 flex items-center justify-center">
                        <div class="text-center">
                            <div class="text-6xl mb-2 rotate-12">🏐</div>
                            <p class="font-black">POWER!</p>
                            <p class="text-xs mt-2">如同排球場上的殺球<br>精準打擊數據痛點</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- EPISODE 2: 戰鬥技能 / 技術核心 -->
            <div id="page-tech" class="content-section">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div class="manga-panel p-4 border-l-8 border-l-red-500">
                        <h3 class="font-black text-lg mb-2 underline">智慧化數據分析</h3>
                        <p class="text-sm leading-snug">利用 <span class="font-bold">Python</span> 進行大數據清洗與機器學習建模（Random Forest, XGBoost），將廣告投放自動化，實現精準預測。</p>
                    </div>
                    <div class="manga-panel p-4 border-l-8 border-l-blue-500">
                        <h3 class="font-black text-lg mb-2 underline">生成式 AI 行銷</h3>
                        <p class="text-sm leading-snug">運用 <span class="font-bold">LLM API</span> 與 Prompt Engineering，開發自動化文案與社群腳本，大幅提升 SEO 效能。</p>
                    </div>
                    <div class="manga-panel p-4 border-l-8 border-l-green-500">
                        <h3 class="font-black text-lg mb-2 underline">物聯網整合 (AIOT)</h3>
                        <p class="text-sm leading-snug">掌握感測器數據採集與雲端平台整合，將實體環境數據回傳資料庫，支援即時監控與決策。</p>
                    </div>
                    <div class="manga-panel p-4 border-l-8 border-l-yellow-500">
                        <h3 class="font-black text-lg mb-2 underline">邊緣運算 CV</h3>
                        <p class="text-sm leading-snug">具備 <span class="font-bold">OpenCV</span> 影像辨識基礎，應用於智慧零售人流分析與物件偵測。</p>
                    </div>
                </div>
                <!-- 技能條 -->
                <div class="manga-panel p-4 bg-gray-50">
                    <h3 class="font-black mb-3">冒險者各項指標 (Skills)</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3">
                        <div class="space-y-1">
                            <p class="text-xs font-bold">PYTHON / SQL / ML</p>
                            <div class="skill-bar-container"><div class="skill-bar-fill bg-blue-500" style="width: 80%"></div></div>
                        </div>
                        <div class="space-y-1">
                            <p class="text-xs font-bold">DIGITAL MARKETING / GA4</p>
                            <div class="skill-bar-container"><div class="skill-bar-fill bg-red-500" style="width: 90%"></div></div>
                        </div>
                        <div class="space-y-1">
                            <p class="text-xs font-bold">PROMPT ENGINEERING</p>
                            <div class="skill-bar-container"><div class="skill-bar-fill bg-yellow-400" style="width: 85%"></div></div>
                        </div>
                        <div class="space-y-1">
                            <p class="text-xs font-bold">ENGLISH (TOEIC 640)</p>
                            <div class="skill-bar-container"><div class="skill-bar-fill bg-green-500" style="width: 65%"></div></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- EPISODE 3: 任務成果 / 數據亮點 -->
            <div id="page-exp" class="content-section">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <!-- 專業經歷 -->
                    <div class="manga-panel md:col-span-2 p-6">
                        <h3 class="text-xl font-black mb-4 border-b-2 border-black">💼 專業經歷：台灣知識庫</h3>
                        <div class="space-y-4">
                            <div class="relative pl-6 before:content-['●'] before:absolute before:left-0 before:text-red-500">
                                <p class="font-black text-sm">AI 輔助社群經營 (2023-2024)</p>
                                <p class="text-xs text-gray-700">導入生成式 AI 輔助 IG/FB/Threads 內容創作，達成 <span class="font-bold text-red-600">200%</span> 粉絲成長。</p>
                            </div>
                            <div class="relative pl-6 before:content-['●'] before:absolute before:left-0 before:text-blue-500">
                                <p class="font-black text-sm">自動化廣告優化</p>
                                <p class="text-xs text-gray-700">利用數據追蹤技術監測 Google/Meta Ads 走勢，即時調整策略。</p>
                            </div>
                            <div class="relative pl-6 before:content-['●'] before:absolute before:left-0 before:text-yellow-500">
                                <p class="font-black text-sm">GA4 導流轉化策略</p>
                                <p class="text-xs text-gray-700">分析數據挖掘潛在痛點，策劃高轉換活動方案。</p>
                            </div>
                        </div>
                        <div class="mt-6 pt-4 border-t border-dashed border-gray-400">
                            <p class="text-[0.65rem] font-bold">EDUCATION: 國立嘉義大學 - 行銷與觀光管理 | AIOT 實務班 (結業)</p>
                        </div>
                    </div>
                    <!-- 數據亮點 -->
                    <div class="space-y-4">
                        <div class="manga-panel p-4 speed-lines bg-yellow-50 flex flex-col items-center justify-center">
                            <p class="impact-text text-3xl">50%+</p>
                            <p class="text-[0.6rem] font-black text-center mt-1">AI 自動化縮短<br>報表產製時間</p>
                        </div>
                        <div class="manga-panel p-4 bg-red-50 flex flex-col items-center justify-center">
                            <p class="impact-text text-3xl">1M+</p>
                            <p class="text-[0.6rem] font-black text-center mt-1">Google & Meta<br>累積百萬曝光</p>
                        </div>
                        <div class="manga-panel p-4 bg-blue-50 flex flex-col items-center justify-center">
                            <p class="impact-text text-3xl">35%</p>
                            <p class="text-[0.6rem] font-black text-center mt-1">轉換率優化<br>精準鎖定客群</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- EPISODE 4: 畫廊 / 作品集 -->
            <div id="page-gallery" class="content-section">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="manga-panel p-2 group">
                        <div class="bg-yellow-300 text-[0.65rem] font-bold px-1 mb-1">AI 視覺：勝昌 x 龍珠</div>
                        <div class="relative aspect-square bg-gray-200 overflow-hidden">
                            <img src="作品及1.jfif" alt="勝昌中藥龍珠" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition duration-500">
                        </div>
                        <p class="text-[0.55rem] mt-2 italic">利用 AI 生成技術輔助設計之風格化貼文</p>
                    </div>
                    <div class="manga-panel p-2 group">
                        <div class="bg-blue-300 text-[0.65rem] font-bold px-1 mb-1">產品 AI 渲染設計</div>
                        <div class="relative aspect-square bg-gray-200 overflow-hidden">
                            <img src="作品及2.jpg" alt="AI渲染設計" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition duration-500">
                        </div>
                        <p class="text-[0.55rem] mt-2 italic">Python 數據報表與預測模型之視覺化展示</p>
                    </div>
                    <div class="manga-panel p-2 group">
                        <div class="bg-red-300 text-[0.65rem] font-bold px-1 mb-1">AI 風格化處理</div>
                        <div class="relative aspect-square bg-gray-200 overflow-hidden">
                            <img src="產品ai渲染設計.jpg" alt="AI風格化" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition duration-500">
                        </div>
                        <p class="text-[0.55rem] mt-2 italic">將 AIOT 思維應用於數位廣告實作案例</p>
                    </div>
                </div>
                <div class="manga-panel mt-4 p-4 bg-black text-white text-center">
                    <p class="font-black italic text-sm">"FROM MARKETING DATA TO INTELLIGENT SYSTEMS"</p>
                </div>
            </div>

        </div>

        <!-- 導覽控制器 -->
        <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-2 relative z-10">
            <button class="manga-nav-btn active" onclick="switchPage('home', this)">序幕: 使命</button>
            <button class="manga-nav-btn" onclick="switchPage('tech', this)">技能: 核心</button>
            <button class="manga-nav-btn" onclick="switchPage('exp', this)">戰績: 成果</button>
            <button class="manga-nav-btn" onclick="switchPage('gallery', this)">畫廊: 作品</button>
        </div>

        <div class="mt-6 text-right border-t-2 border-black pt-2">
            <p class="font-black text-xs italic">TO BE CONTINUED IN THE AI ERA...</p>
        </div>

    </div>

    <script>
        function switchPage(pageId, btn) {
            document.querySelectorAll('.content-section').forEach(section => {
                section.classList.remove('active');
            });
            document.getElementById('page-' + pageId).classList.add('active');

            document.querySelectorAll('.manga-nav-btn').forEach(b => {
                b.classList.remove('active');
            });
            btn.classList.add('active');

            // 隨機切換主題色特效
            const colors = ['#ff0000', '#0000ff', '#ffff00', '#00cc00'];
            const randomColor = colors[Math.floor(Math.random() * colors.length)];
            document.querySelector('.manga-title').style.borderColor = randomColor;
        }
    </script>
</body>
</html>
